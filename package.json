{
  "name": "traytools-26-go-root",
  "version": "1.0.0",
  "description": "Go tool to collect diagnostic traces",
  "private": true,
  "author": {
    "name": "Max Zakharzhevskiy",
    "email": "maxzz@msn.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "wails dev",
    "build": "wails build --clean --platform windows/amd64",
    "build:all": "wails build --clean",
    "build:macos": "wails build --clean --platform darwin/amd64",
    "build:macos-arm": "wails build --clean --platform darwin/arm64",
    "frontend:install": "pnpm --prefix frontend install",
    "frontend:build": "pnpm --prefix frontend run build",
    "frontend:dev": "pnpm --prefix frontend run dev",
    "go:fmt": "go fmt ./...",
    "go:vet": "go vet ./...",
    "go:test": "go test ./...",
    "wails:doctor": "wails doctor"
  }
}
