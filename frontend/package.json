        "globals": "^17.7.0",
        "jotai-family": "^1.0.2",
        "rollup-plugin-visualizer": "^7.0.1",
        "tailwindcss-plugin-debug-screens-tw4": "^1.0.4",
        "tailwindcss-plugin-overflow-tw4": "^1.0.1",
        "tsx": "^4.22.4",
        "typescript": "~6.0.2",
        "upen": "^1.0.2",
        "vite": "^8.1.0",
        "vitest": "^4.1.8"
    },
    "dependencies": {
        "@fontsource-variable/geist": "^5.2.9",
        "@fontsource-variable/geist-mono": "^5.2.8",
